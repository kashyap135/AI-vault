{
  "manifest_version": 3,
  "name": "AI Vault",
  "version": "1.0",
  "description": "Universal privacy lock for ChatGPT, Gemini, and Claude.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ],
      "js": [
        "adapters/chatgpt.js",
        "adapters/gemini.js",
        "adapters/claude.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ]
}